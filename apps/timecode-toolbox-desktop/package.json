{
  "name": "@arcanewizards/timecode-toolbox-desktop",
  "productName": "Timecode Toolbox Desktop",
  "description": "Monitor, generate and convert timecodes easily",
  "author": "Arcane Wizards Ltd.",
  "version": "0.1.3",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArcaneWizards/open-source.git",
    "directory": "apps/timecode-toolbox-desktop"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --max-warnings 0 --fix",
    "check:types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "pnpm check:types && pnpm clean && cp ../../LICENSE ./LICENSE &&pnpm build:main && pnpm build:preload && pnpm build:frontend",
    "build:workspace": "pnpm -r --filter @arcanewizards/timecode-toolbox-desktop... build",
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --external:@arcanewizards/electron-media-service --outfile=dist/main.js",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/preload.js",
    "build:frontend": "esbuild src/frontend.ts --bundle --platform=browser --format=iife --conditions=@arcanewizards/source --outfile=dist/frontend.js",
    "start": "pnpm build && electron-forge start",
    "package": "pnpm build && electron-forge package",
    "make": "pnpm build && electron-forge make",
    "version-sync": "jq -r '.version' ../timecode-toolbox/package.json | xargs -I {} jq --arg version {} '.version = $version' package.json > package.new.json && mv package.new.json package.json"
  },
  "dependencies": {
    "@arcanewizards/electron-media-service": "^0.3.1",
    "bindings": "^1.5.0",
    "file-uri-to-path": "^1.0.0",
    "material-symbols": "^0.25.0",
    "nan": "^2.23.1",
    "semver": "^5.3.0"
  },
  "devDependencies": {
    "@arcanewizards/eslint-config": "workspace:^",
    "@arcanewizards/sigil": "workspace:^",
    "@arcanewizards/timecode-toolbox": "workspace:^",
    "@arcanewizards/typescript-config": "workspace:^",
    "@eslint/js": "^9.33.0",
    "@eslint/eslintrc": "^3.3.1",
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.8.3",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron": "^33.3.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-turbo": "^2.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.3"
  }
}
