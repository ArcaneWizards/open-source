{
  "name": "@arcane-wizards/open-source",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo build",
    "pre-deploy:web": "TURBO_TELEMETRY_DISABLED=1 turbo pre-deploy --filter=web",
    "check:types": "TURBO_TELEMETRY_DISABLED=1 turbo check:types",
    "dev": "TURBO_TELEMETRY_DISABLED=1 turbo dev",
    "lint": "TURBO_TELEMETRY_DISABLED=1 turbo lint",
    "lint:fix": "TURBO_TELEMETRY_DISABLED=1 turbo lint -- --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,css}\"",
    "test": "TURBO_TELEMETRY_DISABLED=1 turbo test",
    "test:watch": "TURBO_TELEMETRY_DISABLED=1 turbo test:watch",
    "start": "cd apps/server && pnpm start"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.6",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "typescript": "^5.7.3"
  }
}
