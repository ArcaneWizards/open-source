{
  "name": "@arcane-wizards/open-source",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "pre-deploy:web": "turbo pre-deploy --filter=web",
    "check:types": "turbo check:types",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,css}\"",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "start": "cd apps/server && pnpm start",
    "version": "changeset version && pnpm --dir apps/timecode-toolbox-desktop version-sync"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "engines": {
    "node": ">=22"
  },
  "resolutions": {
    "typescript": "^5.7.3"
  }
}
