{
  "name": "@arcanewizards/midi",
  "version": "0.1.3",
  "private": false,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArcaneWizards/open-source.git",
    "directory": "packages/midi"
  },
  "exports": {
    ".": {
      "@arcanewizards/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "native/midi-macos.mm",
    "native/midi-windows.cpp",
    "scripts/build-native.mjs"
  ],
  "scripts": {
    "build": "pnpm clean && tsup && node scripts/build-native.mjs && check-export-map",
    "clean": "rm -rf dist && rm -rf native/out",
    "check:types": "tsc --noEmit",
    "format:fix": "cd .. && pnpm format:fix",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "postinstall": "node scripts/build-native.mjs",
    "test": "pnpm build && jest --runInBand",
    "test:integration": "pnpm build && node scripts/test-integration.mjs run",
    "test:integration:virtual": "pnpm build && node scripts/test-integration.mjs virtual",
    "test:integration:list": "pnpm build && node scripts/test-integration.mjs list"
  },
  "devDependencies": {
    "@arcanewizards/eslint-config": "workspace:^",
    "@arcanewizards/typescript-config": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "check-export-map": "^1.3.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0 || >=23.1.0"
  }
}
